name = "avtonomny-agent-subscribers"
main = "worker/src/index.js"
compatibility_date = "2024-08-01"
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

[[d1_databases]]
binding = "DB"
database_name = "subscribers"
database_id = "YOUR_D1_DATABASE_ID"

[vars]
# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS = "https://googlepro1.github.io,https://YOUR_DOMAIN,http://127.0.0.1:8080,http://localhost:8080"
